# Copy this file to .env and fill in values. .env is gitignored.

# Voyage AI — for embedding chunks (voyage-3.5-lite at 512 dimensions)
# Get a key at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# Neon Postgres connection string — for writing parsed chunks + embeddings
# Format: postgresql://user:password@host/database?sslmode=require
# Get from: Neon project dashboard → "Connection Details" → "psql" tab
DATABASE_URL=

# Anthropic — only needed by apps/api, not by ingest. Included here so the
# infra/check_connections.py smoke test can verify all three at once.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
