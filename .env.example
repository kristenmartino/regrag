# Copy this file to .env and fill in values. .env is gitignored.

# Voyage AI — for embedding chunks (voyage-3.5-lite at 512 dimensions)
# Get a key at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# Neon Postgres connection string — for writing parsed chunks + embeddings
# Format: postgresql://user:password@host/database?sslmode=require
# Get from: Neon project dashboard → "Connection Details" → "psql" tab
DATABASE_URL=

# Anthropic — only needed by apps/api, not by ingest. Included here so the
# infra/check_connections.py smoke test can verify all three at once.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Admin token gating the /audit endpoints (issue #11). If UNSET, the audit log
# is DISABLED (default-deny): /audit and /audit/{id} return 403 for everyone.
# Set it to a long random string to enable the audit UI — the frontend prompts
# for it and sends it as a bearer token. Generate one with: openssl rand -hex 32
REGRAG_AUDIT_TOKEN=
